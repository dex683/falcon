# ─── Skeem Backend — Environment Variables ───────────────────────────

# Set to 1 to use Gemini Vision API instead of the mock ML model
# Accepted values: 1, true, yes, on
USE_GEMINI_FALLBACK=0

# Required when USE_GEMINI_FALLBACK=1
# Get your key at https://aistudio.google.com/
GEMINI_API_KEY=your_api_key_here
